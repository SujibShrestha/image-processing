{
  "name": "image-backend",
  "version": "1.0.0",
  "description": "Backend API for image processing application with Express and TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx --watch src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings=0 --rule \"indent: off\" --rule \"semi: off\" --rule \"quotes: off\" --rule \"@typescript-eslint/no-unused-vars: off\"",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest"
  },
  "keywords": [
    "image-processing",
    "typescript",
    "express",
    "api",
    "backend"
  ],
  "author": "Sujib Shrestha",
  "repository": {
    "type": "git",
    "url": "https://github.com/SujibShrestha/image-processing.git"
  },
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "supertest": "^7.2.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "prisma": "^7.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
